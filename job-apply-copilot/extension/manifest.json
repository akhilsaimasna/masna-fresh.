{
    "manifest_version": 3,
    "name": "OpenClaw Auto-Fill",
    "version": "1.0.0",
    "description": "Auto-fill job applications on Greenhouse and Lever using your OpenClaw AI Kits.",
    "action": {
        "default_popup": "popup.html",
        "default_title": "OpenClaw"
    },
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:3000/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://boards.greenhouse.io/*",
                "https://jobs.lever.co/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}